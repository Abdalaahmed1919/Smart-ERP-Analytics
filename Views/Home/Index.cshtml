@{
    ViewData["Title"] = "Home Page";
}

<div class="page-header">
    <div class="page-title">Welcome back, Admin User</div>
    <div class="page-sub">Access your modules and manage your operations</div>
</div>

<!-- Module Cards Row 1 -->
<div class="row g-3 mb-3">
    <div class="col-6 col-lg-3">
        <a href="purchase.html" class="module-card">
            <div class="module-icon" style="background:#eff6ff;color:#2563eb;"><i class="fa-solid fa-cart-shopping"></i></div>
