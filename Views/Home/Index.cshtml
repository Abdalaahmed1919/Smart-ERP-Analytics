            <p>Manage purchase orders, vendors, and procurement</p>
            <span class="open-link">Open module <i class="fa-solid fa-arrow-right"></i></span>
        </a>
    </div>
    <div class="col-6 col-lg-3">
        <a href="sales.html" class="module-card">
            <div class="module-icon" style="background:#e6f9f1;color:#1db97a;"><i class="fa-solid fa-chart-line"></i></div>
